# ==========================================
# CONFIGURACIÓN DE LA TIENDA WOOCOMMERCE
# Copia este archivo como ".env" antes de levantar el sitio
# ==========================================

# Configuración del dominio para el Proxy Inverso y Certificados SSL (HTTPS)
# Cambia esto por el dominio real de tu tienda (y opcionalmente subdominios)
# Ejemplo: VIRTUAL_HOST=mi-tienda.cl,www.mi-tienda.cl
VIRTUAL_HOST=mi-tienda1.com

# Habilitar SSL Automático con Let's Encrypt
# Deben coincidir exactamente con los dominios definidos en VIRTUAL_HOST
LETSENCRYPT_HOST=mi-tienda1.com
LETSENCRYPT_EMAIL=admin@tudominio.com

# ==========================================
# CREDENCIALES DE BASE DE DATOS
# Cambia las contraseñas para producción!
# ==========================================
DB_ROOT_PASSWORD=root_password_super_seguro_123
DB_NAME=woo_database
DB_USER=woo_user
DB_PASSWORD=woo_password_segura_456
